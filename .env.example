# Copy this file to ".env.local" and fill in your key, then restart `npm run dev`.
# .env.local is gitignored so your key is never committed.

# Google Gemini API key (free tier): https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional: override the model. Defaults to a free-tier flash model.
# Examples: gemini-2.5-flash, gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.5-flash

# Supabase — when BOTH are set, the app uses Supabase instead of localStorage.
# Find them in: Supabase Dashboard → Project Settings → Data API (and API Keys).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to "true" to REQUIRE an access code to use the app (shows the login
# screen until signed in). Leave unset/false while setting up access codes.
# First run supabase-members.sql, sign in with ARETE-ADMIN, then enable this.
VITE_REQUIRE_LOGIN=

# Set to "true" to route all data through the secure Edge Function (required
# once RLS is enabled). Deploy supabase/functions/data first, then flip this on.
VITE_USE_EDGE=
